# ============================================================================
# Vera — Voice of Customer Intelligence Agent
# Copy this file to .env and fill in your values.
# ============================================================================

# --- API Keys ---------------------------------------------------------------
GROQ_API_KEY=your_groq_api_key_here
SCRAPER_API_KEY=your_scraperapi_key_here

# --- Product A --------------------------------------------------------------
PRODUCT_A_ID=product_a
PRODUCT_A_NAME=Product A

# Provide 1–10 URLs per product. The scraper reads _1 through _10 and stops
# at the first empty slot. Each URL is also scraped with 4 sort variants
# (&sort=MOST_HELPFUL, POSITIVE_FIRST, NEGATIVE_FIRST, RECENT) automatically.
PRODUCT_A_URL_1=   # main product / reviews page
PRODUCT_A_URL_2=   # all reviews page
PRODUCT_A_URL_3=   # sorted by recent
PRODUCT_A_URL_4=   # sorted by helpful
PRODUCT_A_URL_5=   # sorted by positive
PRODUCT_A_URL_6=   # sorted by negative / critical
# PRODUCT_A_URL_7=
# PRODUCT_A_URL_8=
# PRODUCT_A_URL_9=
# PRODUCT_A_URL_10=

# --- Product B --------------------------------------------------------------
PRODUCT_B_ID=product_b
PRODUCT_B_NAME=Product B

PRODUCT_B_URL_1=
PRODUCT_B_URL_2=
PRODUCT_B_URL_3=
PRODUCT_B_URL_4=
PRODUCT_B_URL_5=
PRODUCT_B_URL_6=
# PRODUCT_B_URL_7=
# PRODUCT_B_URL_8=
# PRODUCT_B_URL_9=
# PRODUCT_B_URL_10=

# --- Platform ----------------------------------------------------------------
SCRAPE_PLATFORM=flipkart

# --- Telegram (optional) ----------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
